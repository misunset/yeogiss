        "selector": "JSXOpeningElement[name.name='FeaturedIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|theme|shape|className|style|children|key|ref|className|style|children)$/]",
        "message": "<FeaturedIcon> doesn't accept that prop. Declared props: name, size, color, theme, shape, className, style, children."
      },
