{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/app/**",
              "components/buttons/**",
              "components/feedback/**",
              "components/forms/**",
              "components/foundations/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/trash-finder/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Sans KR|Inter|Roboto Mono))/i]",
        "message": "Font not provided by the design system. Available: Noto Sans KR, Inter, Roboto Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initials|size|online|className|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, initials, size, online, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|size|dot|icon|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, size, dot, icon, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:gray|brand|success|warning|error|blue)$/]",
        "message": "<Badge> color must be one of 'gray' | 'brand' | 'success' | 'warning' | 'error' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|children|icon|onClose|action|className|style|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: variant, title, children, icon, onClose, action, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|brand|success|warning|error)$/]",
        "message": "<Banner> variant must be one of 'info' | 'brand' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BinPin'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|selected|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<BinPin> doesn't accept that prop. Declared props: type, selected, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|showScrim|handle|children|className|style|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: open, onClose, showScrim, handle, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hierarchy|size|iconLeading|iconTrailing|iconOnly|destructive|disabled|fullWidth|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, hierarchy, size, iconLeading, iconTrailing, iconOnly, destructive, disabled, fullWidth, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='hierarchy'] > Literal[value!=/^(?:primary|secondary-gray|secondary-color|tertiary|link)$/]",
        "message": "<Button> hierarchy must be one of 'primary' | 'secondary-gray' | 'secondary-color' | 'tertiary' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
